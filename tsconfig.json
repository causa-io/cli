{
  "extends": "@tsconfig/node20/tsconfig.json",
  "compilerOptions": {
    "types": [
      "node",
      "jest"
    ],
    "declaration": true,
    "removeComments": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "sourceMap": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "verbatimModuleSyntax": true
  }
}
